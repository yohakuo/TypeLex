{
  "name": "wordspell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:logic && npm run test:ui",
    "test:logic": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.ui.config.ts",
